#!/usr/bin/env bash
# sancla — launch Claude Code with secret-looking env vars stripped.
#
# Model: pass-through denylist. Inherit the full shell environment (so anything
# your tools inject later just works), then UNSET any var whose NAME matches a
# BLOCK word. KEEP lists exact names to preserve even if they match — for keys an
# agent genuinely needs (e.g. OPENAI_API_KEY).
#
# This is a light hygiene layer, not a wall: the OS sandbox (filesystem/network)
# and the auto-mode classifier are the real guards against misuse. A secret whose
# NAME contains no common word (e.g. ACME_DEPLOY_XYZ) will pass through — that's
# the accepted trade for low maintenance; the sandbox/network limit contains it.
#
# Runs at LAUNCH (in your shell, which holds launchd session vars), so it catches
# things the old SessionStart hook could not — e.g. CLOUDSDK_PROXY_PASSWORD.

set -euo pipefail

# --- BLOCK: case-insensitive substring patterns on the var NAME → unset --------
BLOCK=(
	TOKEN SECRET PASSWORD PASSWD PASSPHRASE
	API_KEY APIKEY ACCESS_KEY SECRET_KEY PRIVATE_KEY
	CREDENTIAL AUTH_TOKEN SESSION_KEY
)

# --- KEEP: exact names kept even if they match BLOCK (the exceptions) ----------
KEEP=(
	# OPENAI_API_KEY
)
# Per-launch extra exceptions:  SANCLA_KEEP="OPENAI_API_KEY" sancla
if [ -n "${SANCLA_KEEP:-}" ]; then
	# shellcheck disable=SC2206
	KEEP+=(${SANCLA_KEEP})
fi

block_re="$(
	IFS='|'
	printf '%s' "${BLOCK[*]}"
)"
keep_list=" ${KEEP[*]:-} "

# Strip secret-looking names from the current env (except KEEP). unset here
# affects this shell, so the exec'd claude inherits the cleaned environment.
stripped=()
while IFS= read -r name; do
	case "$keep_list" in *" $name "*) continue ;; esac # explicit keep wins
	if printf '%s' "$name" | grep -qiE "$block_re"; then
		unset "$name" 2>/dev/null || true
		stripped+=("$name")
	fi
done < <(env | grep -E '^[A-Za-z_][A-Za-z0-9_]*=' | cut -d= -f1)

# Debug: names only (never values), then exit without launching.
if [ "${SANCLA_DEBUG:-}" = "1" ]; then
	printf 'stripped: %s\n' "${stripped[*]:-<none>}"
	printf 'kept-exc: %s\n' "${KEEP[*]:-<none>}"
	exit 0
fi

claude_bin="$(command -v claude || true)"
if [ -z "$claude_bin" ]; then
	printf 'sancla: claude not found on PATH\n' >&2
	exit 127
fi

exec "$claude_bin" "$@"
