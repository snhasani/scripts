#!/usr/bin/env bash
# rig — bootstrap a repo for the agent-skills collection.
#
# Model: a repo adopting the skills needs per-repo config in the places the
# skills already read — a marker-wrapped `rig:config` block in the agent file
# (AGENTS.md/CLAUDE.md, already in every agent's context) and a git-ignored
# scratch root (.tmp/). rig inspects the repo, proposes defaults, and writes
# only inside its own markers/lines, so a re-run adds nothing and clobbers
# nothing.
#
# Engine: each concern is a SECTION — a set of shell functions shaped
# detect → draft → apply — walked from an ordered registry by the main loop,
# which supplies the shared confirm phase (auto-yes when headless). Idempotency
# is per-section: the config block is guarded by its markers (grep → replace in
# place, else append); scratch is guarded by `git check-ignore`; domain files by
# existence. A new section is a function trio + one registry entry.
#
# The rig:config block is a single marker-guarded region assembled by one pure
# function (config_block): tracker line + optional triage map. The block-owning
# sections (agent-file, tracker, triage) each re-upsert that deterministic
# content, so order and repetition are irrelevant — the final bytes are fixed.
#
# Anchoring: all paths resolve under `git rev-parse --show-toplevel`; rig
# refuses to run outside a git repo. --dry-run prints the intended edits and
# writes nothing.

set -euo pipefail

# --- constants ---------------------------------------------------------------
CONFIG_OPEN='<!-- rig:config -->'
CONFIG_CLOSE='<!-- /rig:config -->'
SCRATCH_DIR='.tmp'
# Footprint above the scratch ignore line so a reader knows rig added it and why
# (parity with the marker-wrapped config block and the domain-seed comment).
SCRATCH_NOTE='# rig: agent-skills scratch root (git-ignored ephemeral state)'

# --- ordered section registry ------------------------------------------------
# tracker/triage refine the config block agent-file writes; domain scaffolds.
SECTIONS=(agent-file tracker triage scratch domain)

# --- flags / state -----------------------------------------------------------
ASSUME_YES=0
DRY_RUN=0
DEBUG=0
# Per-section skip reason: a section returns non-zero from detect (nothing to
# do) and may set this to explain why; the main loop prints and clears it.
SKIP_MSG=""

# --- logging (names/decisions only, colored like the toolbox reference) ------
info() { printf '%s\n' "$*"; }
step() { printf '  %s\n' "$*"; }
note() { printf '\033[33m%s\033[0m\n' "$*"; }
err() { printf 'rig: %s\n' "$*" >&2; }
debug() { [ "$DEBUG" -eq 1 ] && printf '\033[2mrig[debug] %s\033[0m\n' "$*" >&2 || true; }

usage() {
	cat <<'EOF'
rig — bootstrap a repo for the agent-skills collection.

usage: rig [options]

options:
  -y, --yes       headless: accept detected defaults, no prompts
  -h, --help      show this help and exit
  -v, --debug     verbose diagnostics on stderr
      --dry-run   print the intended edits, write nothing

env (detected defaults; override to force):
  RIG_AGENT_FILE        agent file to use/create, must resolve within the repo (default: AGENTS.md, else CLAUDE.md)
  RIG_TRACKER           tracker backend: github | shortcut (default: github)
  RIG_REPO              repo slug for the github backend (default: from origin remote)
  RIG_SHORTCUT_WORKSPACE  workspace for the shortcut backend
  RIG_SKILLS_DIR        skills collection to probe for a `triage` skill (default: ~/skills)
  RIG_TRIAGE            force triage on/off: 1 | 0 (default: auto-detect via skills dir)

Sections (registry order): agent-file, tracker, triage, scratch, domain.
  agent-file  ensure AGENTS.md/CLAUDE.md, upsert the marker-wrapped rig:config block
  tracker     write tracker: { backend, repo|workspace } into rig:config (case seam)
  triage      only when a `triage` skill is present: write triage.labels into rig:config
  scratch     provision + git-ignore the .tmp/ scratch root
  domain      scaffold the domain-doc layout (single- or multi-context)

The Shortcut API token is read from $SHORTCUT_API_TOKEN at skill-runtime and is
NEVER written into the config block. Idempotent and non-destructive: a re-run
adds no duplicate keys or files and leaves content outside rig's markers/files
byte-for-byte.
EOF
}

# --- arg parsing -------------------------------------------------------------
while [ $# -gt 0 ]; do
	case "$1" in
	-y | --yes) ASSUME_YES=1 ;;
	-h | --help)
		usage
		exit 0
		;;
	-v | --debug) DEBUG=1 ;;
	--dry-run) DRY_RUN=1 ;;
	--)
		shift
		break
		;;
	-*)
		err "unknown option: $1"
		usage >&2
		exit 2
		;;
	*)
		err "unexpected argument: $1"
		exit 2
		;;
	esac
	shift
done

# --- anchor: refuse outside a git repo ---------------------------------------
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
	err "not inside a git repository (run rig from within a repo)"
	exit 1
fi
cd "$ROOT"
debug "repo root: $ROOT"

# --- shared engine helpers ---------------------------------------------------

# confirm: the lifecycle's confirm phase. Auto-yes when headless (--yes or a
# non-TTY stdin) so rig runs unattended; a plain-bash prompt otherwise.
confirm() {
	if [ "$ASSUME_YES" -eq 1 ] || [ ! -t 0 ]; then
		return 0
	fi
	printf '%s [y/N] ' "$1"
	local reply
	read -r reply || return 1
	case "$reply" in
	[yY] | [yY][eE][sS]) return 0 ;;
	*) return 1 ;;
	esac
}

# upsert_block: write CONTENT between the config markers in FILE. If the open
# marker is present, replace the marked region in place; else append the block.
# Deterministic CONTENT => a re-run reproduces byte-identical output. Temp files
# sit beside FILE (same filesystem for an atomic mv, and no dependency on a
# writable system TMPDIR — rig runs inside restrictive sandboxes).
upsert_block() {
	local file="$1" content="$2"
	local blk="${file}.rig-blk.$$" tmp="${file}.rig-new.$$"
	printf '%s\n' "$content" >"$blk"
	if grep -qF "$CONFIG_OPEN" "$file" 2>/dev/null; then
		awk -v om="$CONFIG_OPEN" -v cm="$CONFIG_CLOSE" -v blk="$blk" '
			function dump(  line) { while ((getline line < blk) > 0) print line; close(blk) }
			$0 == om { dump(); skip = 1; next }
			skip && $0 == cm { skip = 0; next }
			skip { next }
			{ print }
		' "$file" >"$tmp"
		mv "$tmp" "$file"
	else
		[ -s "$file" ] && printf '\n' >>"$file"
		cat "$blk" >>"$file"
	fi
	rm -f "$blk" "$tmp"
}

# resolve_path: absolute, `.`/`..`-normalized form of PATH, taken relative to
# $ROOT (already cd'd there) when not absolute. Purely lexical — no filesystem
# access — so it resolves a not-yet-created file and cannot be fooled into
# treating `/rootsibling` as inside `/root`. Used to keep every touched path
# anchored under the repo root.
resolve_path() {
	local p="$1" seg out='' segs
	case "$p" in
	/*) ;;
	*) p="$ROOT/$p" ;;
	esac
	IFS='/' read -ra segs <<<"$p"
	for seg in "${segs[@]}"; do
		case "$seg" in
		'' | .) ;;
		..) out="${out%/*}" ;;
		*) out="${out}/${seg}" ;;
		esac
	done
	printf '%s' "${out:-/}"
}

# path_under_root: true IFF PATH normalizes to $ROOT or a descendant of it.
path_under_root() {
	local abs
	abs="$(resolve_path "$1")"
	case "$abs" in
	"$ROOT" | "$ROOT"/*) return 0 ;;
	*) return 1 ;;
	esac
}

# detect_repo_slug: owner/name from the origin remote for a sensible tracker
# default; `unknown` when there is no remote (keeps the block valid YAML).
detect_repo_slug() {
	local url name rest owner
	url="$(git remote get-url origin 2>/dev/null || true)"
	if [ -z "$url" ]; then
		printf 'unknown'
		return 0
	fi
	url="${url%.git}"
	url="${url%/}"
	case "$url" in
	*/*) ;;
	*)
		printf 'unknown'
		return 0
		;;
	esac
	name="${url##*/}"
	rest="${url%/*}"
	owner="${rest##*[:/]}"
	if [ -n "$owner" ] && [ -n "$name" ]; then
		printf '%s/%s' "$owner" "$name"
	else
		printf 'unknown'
	fi
}

# config_block: the whole rig:config block, assembled from the section fragments.
# Pure and deterministic (reads env, the origin remote, and the skills dir — all
# stable within a run), so every re-upsert reproduces byte-identical output. The
# tracker line always contributes; the triage map only when a triage skill is
# present.
config_block() {
	local body
	body="$(tracker_line)"
	if triage_present; then
		body="${body}"$'\n'"$(triage_yaml)"
	fi
	printf '%s\n%s\n%s\n%s\n%s' \
		"$CONFIG_OPEN" \
		'```yaml' \
		"$body" \
		'```' \
		"$CONFIG_CLOSE"
}

# sync_config: re-assemble and upsert the rig:config block into the agent file.
# Shared by the block-owning sections (agent-file, tracker, triage); idempotent
# because config_block is deterministic and upsert_block replaces in place.
sync_config() {
	upsert_block "$AF_PATH" "$(config_block)"
}

# --- section: agent-file -----------------------------------------------------
# Ensure the agent file exists (real AGENTS.md + CLAUDE.md symlink when neither
# exists; use whichever exists, never overwrite a plain file), then upsert the
# rig:config block.
agent_file_detect() {
	AF_CREATE_FILE=0
	AF_CREATE_SYMLINK=0
	local forced="${RIG_AGENT_FILE:-}"
	if [ -n "$forced" ]; then
		if ! path_under_root "$forced"; then
			err "RIG_AGENT_FILE escapes the repo root ($ROOT): $forced"
			exit 2
		fi
		AF_PATH="$forced"
		if [ ! -e "$AF_PATH" ] && [ ! -L "$AF_PATH" ]; then
			AF_CREATE_FILE=1
		fi
	elif [ -e AGENTS.md ] || [ -L AGENTS.md ]; then
		AF_PATH="AGENTS.md"
	elif [ -e CLAUDE.md ] || [ -L CLAUDE.md ]; then
		AF_PATH="CLAUDE.md"
	else
		AF_PATH="AGENTS.md"
		AF_CREATE_FILE=1
		AF_CREATE_SYMLINK=1
	fi

	AF_BLOCK="$(config_block)"
	if [ "$AF_CREATE_FILE" -eq 1 ]; then
		AF_ACTION="create ${AF_PATH} + rig:config block"
	elif grep -qF "$CONFIG_OPEN" "$AF_PATH" 2>/dev/null; then
		AF_ACTION="update rig:config block in ${AF_PATH}"
	else
		AF_ACTION="insert rig:config block into ${AF_PATH}"
	fi
	return 0
}

agent_file_draft() {
	info "agent-file: ${AF_ACTION}"
	[ "$AF_CREATE_SYMLINK" -eq 1 ] && step "symlink CLAUDE.md -> AGENTS.md"
	printf '%s\n' "$AF_BLOCK" | sed 's/^/    /'
}

agent_file_apply() {
	if [ "$AF_CREATE_FILE" -eq 1 ]; then
		printf '# Agent instructions\n' >"$AF_PATH"
	fi
	if [ "$AF_CREATE_SYMLINK" -eq 1 ]; then
		ln -s AGENTS.md CLAUDE.md
	fi
	upsert_block "$AF_PATH" "$AF_BLOCK"
}

# --- section: scratch --------------------------------------------------------
# Provision the fixed scratch root .tmp/ and git-ignore it via the repo's own
# convention (committed .gitignore if present, else .git/info/exclude).
# `git check-ignore` is the idempotency guard — skip when already ignored.
scratch_detect() {
	SC_MKDIR=0
	SC_IGNORE=0
	SC_TARGET=""
	[ -d "$SCRATCH_DIR" ] || SC_MKDIR=1
	if ! git check-ignore -q "$SCRATCH_DIR"; then
		SC_IGNORE=1
		if [ -f .gitignore ]; then
			SC_TARGET=".gitignore"
		else
			SC_TARGET=".git/info/exclude"
		fi
	fi
	[ "$SC_MKDIR" -eq 1 ] || [ "$SC_IGNORE" -eq 1 ]
}

scratch_draft() {
	info "scratch: ${SCRATCH_DIR}/"
	[ "$SC_MKDIR" -eq 1 ] && step "mkdir ${SCRATCH_DIR}/"
	if [ "$SC_IGNORE" -eq 1 ]; then
		step "add to ${SC_TARGET}:"
		step "  ${SCRATCH_NOTE}"
		step "  ${SCRATCH_DIR}/"
	fi
	return 0
}

scratch_apply() {
	if [ "$SC_MKDIR" -eq 1 ]; then
		mkdir -p "$SCRATCH_DIR"
	fi
	if [ "$SC_IGNORE" -eq 1 ]; then
		# Same newline guard as upsert_block: a target lacking a trailing newline
		# would otherwise glue the footprint onto its last line.
		[ -s "$SC_TARGET" ] && printf '\n' >>"$SC_TARGET"
		printf '%s\n%s/\n' "$SCRATCH_NOTE" "$SCRATCH_DIR" >>"$SC_TARGET"
	fi
}

# --- section: tracker --------------------------------------------------------
# Own the `tracker:` line of the config block. The backend is chosen by a `case`
# seam on RIG_TRACKER (default github); each arm is a small function producing
# one YAML line. A new backend = one function + one case arm — nothing else.
tracker_line() {
	case "${RIG_TRACKER:-github}" in
	github) tracker_github ;;
	shortcut) tracker_shortcut ;;
	*)
		err "unknown RIG_TRACKER: ${RIG_TRACKER:-} (supported: github, shortcut)"
		exit 2
		;;
	esac
}

# github: repo slug from RIG_REPO or the origin remote (owner/name).
tracker_github() {
	local repo="${RIG_REPO:-$(detect_repo_slug)}"
	printf 'tracker: { backend: github, repo: %s }' "$repo"
}

# shortcut: workspace from RIG_SHORTCUT_WORKSPACE. The token lives in
# $SHORTCUT_API_TOKEN at skill-runtime and is deliberately NOT stored here.
tracker_shortcut() {
	printf 'tracker: { backend: shortcut, shortcut_workspace: %s }' \
		"${RIG_SHORTCUT_WORKSPACE:-unknown}"
}

tracker_detect() {
	TRACKER_LINE="$(tracker_line)"
	return 0
}

tracker_draft() {
	info "tracker: into rig:config"
	step "$TRACKER_LINE"
	return 0
}

tracker_apply() {
	sync_config
}

# --- section: triage ---------------------------------------------------------
# Only when a `triage` skill is present, write the five canonical label roles
# into the config block. Presence and the label map are both pure functions, so
# config_block can consult them regardless of section order.

# The five canonical triage roles. Default label string = the role name.
TRIAGE_ROLES=(needs-triage needs-info ready-for-agent ready-for-human wontfix)

# triage_present: true IFF a `triage` skill directory exists in the skills
# collection. RIG_TRIAGE=1/0 forces the answer (deterministic tests); otherwise
# probe `triage/` under RIG_SKILLS_DIR (default ~/skills, the skillshare-managed
# collection the triage skill itself is installed into).
triage_present() {
	case "${RIG_TRIAGE:-}" in
	1) return 0 ;;
	0) return 1 ;;
	esac
	[ -d "${RIG_SKILLS_DIR:-$HOME/skills}/triage" ]
}

# triage_yaml: the `triage:` map. Each role's label defaults to the role name,
# overridable via RIG_TRIAGE_LABEL_<ROLE> (upper-cased, `-` → `_`).
triage_yaml() {
	local role env_name
	printf 'triage:\n  labels:'
	for role in "${TRIAGE_ROLES[@]}"; do
		env_name="RIG_TRIAGE_LABEL_${role^^}"
		env_name="${env_name//-/_}"
		printf '\n    %s: %s' "$role" "${!env_name:-$role}"
	done
}

triage_detect() {
	if ! triage_present; then
		if [ "${RIG_TRIAGE:-}" = "0" ]; then
			SKIP_MSG="disabled (RIG_TRIAGE=0)"
		else
			SKIP_MSG="no triage skill in ${RIG_SKILLS_DIR:-$HOME/skills}"
		fi
		return 1
	fi
	return 0
}

triage_draft() {
	info "triage: into rig:config"
	printf '%s\n' "$(triage_yaml)" | sed 's/^/    /'
	return 0
}

triage_apply() {
	sync_config
}

# --- section: domain ---------------------------------------------------------
# Scaffold the domain-doc layout the domain-modeling skill fills in: single
# context (CONTEXT.md + docs/adr/) by default; multi-context (CONTEXT-MAP.md +
# a per-context CONTEXT.md + docs/adr/) when monorepo signals are present. Files
# are seeded minimal — real content is domain-modeling's job, not rig's. Guarded
# by existence: only-if-absent, so a re-run never clobbers.

# domain_multi_context: monorepo signals (closed set) → multi-context layout.
domain_multi_context() {
	if [ -f pnpm-workspace.yaml ]; then
		return 0
	fi
	if [ -f package.json ] && grep -q '"workspaces"' package.json 2>/dev/null; then
		return 0
	fi
	local d
	for d in packages/*/; do
		[ -d "$d" ] || continue
		if [ -d "${d}src" ]; then
			return 0
		fi
	done
	return 1
}

# domain_contexts: bounded-context dirs — each populated packages/* with its own
# src/. Prints one path per line; empty when none are detectable.
domain_contexts() {
	local d
	for d in packages/*/; do
		[ -d "$d" ] || continue
		[ -d "${d}src" ] && printf '%s\n' "${d%/}"
	done
}

domain_detect() {
	DOMAIN_MULTI=0
	if domain_multi_context; then
		DOMAIN_MULTI=1
	fi
	DOMAIN_FILES=()
	DOMAIN_DIRS=()
	if [ "$DOMAIN_MULTI" -eq 1 ]; then
		[ -e CONTEXT-MAP.md ] || DOMAIN_FILES+=("CONTEXT-MAP.md")
		local ctx
		while IFS= read -r ctx; do
			[ -n "$ctx" ] || continue
			[ -e "${ctx}/CONTEXT.md" ] || DOMAIN_FILES+=("${ctx}/CONTEXT.md")
		done < <(domain_contexts)
	else
		[ -e CONTEXT.md ] || DOMAIN_FILES+=("CONTEXT.md")
	fi
	[ -d docs/adr ] || DOMAIN_DIRS+=("docs/adr")
	[ ${#DOMAIN_FILES[@]} -gt 0 ] || [ ${#DOMAIN_DIRS[@]} -gt 0 ]
}

domain_draft() {
	local layout="single-context"
	[ "$DOMAIN_MULTI" -eq 1 ] && layout="multi-context"
	info "domain: ${layout} scaffold"
	local d f
	for d in "${DOMAIN_DIRS[@]:-}"; do
		[ -n "$d" ] && step "mkdir ${d}/"
	done
	for f in "${DOMAIN_FILES[@]:-}"; do
		[ -n "$f" ] && step "seed ${f}"
	done
	return 0
}

# domain_seed: minimal placeholder for a domain doc — a heading plus a pointer
# to the skill that fills it. Never called on an existing path (detect guards).
domain_seed() {
	local f="$1" title
	case "$f" in
	*CONTEXT-MAP.md) title="Context Map" ;;
	*) title="Context" ;;
	esac
	printf '# %s\n\n<!-- Seeded by rig. Run the domain-modeling skill to fill this in. -->\n' \
		"$title" >"$f"
}

domain_apply() {
	local d f
	for d in "${DOMAIN_DIRS[@]:-}"; do
		[ -n "$d" ] || continue
		mkdir -p "$d"
	done
	for f in "${DOMAIN_FILES[@]:-}"; do
		[ -n "$f" ] || continue
		mkdir -p "$(dirname "$f")"
		domain_seed "$f"
	done
}

# --- main loop: walk the registry through detect → draft → confirm → apply ---
main() {
	info "rig: $ROOT"
	[ "$DRY_RUN" -eq 1 ] && note "dry-run: no changes will be written"
	local section fn
	for section in "${SECTIONS[@]}"; do
		fn="${section//-/_}"
		if ! "${fn}_detect"; then
			info "${section}: ${SKIP_MSG:-already configured}"
			SKIP_MSG=""
			continue
		fi
		"${fn}_draft"
		if [ "$DRY_RUN" -eq 1 ]; then
			continue
		fi
		if confirm "apply ${section}?"; then
			"${fn}_apply"
		else
			note "${section}: skipped"
		fi
	done
}

main
